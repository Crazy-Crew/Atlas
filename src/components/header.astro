---
import Discord from '../../public/assets/icons/discord.svg';
import Kofi from "../../public/assets/icons/kofi.svg";
---

<header>
    <div class="left-grid">
        <a href="https://discord.com/servers/badbones-s-live-chat-182615261403283459"><Discord fill="currentColor"/></a>

        <a href="https://ko-fi.com/ryderbelserion"><Kofi fill="currentColor"/></a>
    </div>

    <div class="center">
        <a href="/" aria-label="home">Home</a>
        <a href="/docs" aria-label="docs">Docs</>
        <a href="/builds" aria-label="builds">Builds</a>
    </div>

    <div class="right">
        <span>Hi</span>
    </div>
</header>

<style lang="scss">
    @use "../styles/variables.scss" as *;

    header {
        display: flex;

        justify-content: center;
        align-items: center;

        background-color: green;

        .center {
            a {
                padding: 10px;
            }

            display: flex;
            justify-content: center;
            flex: 2;
        }

        .left-grid {
            flex: 1;

            display: flex;
            gap: $spacing;

            svg {
              display: flex;

              height: 26px;
              width: 26px;
            }

            svg:hover {
              fill: $primary;
            }
        }

        .right {
            background-color: orangered;
            flex: 1;
        }
    }
</style>